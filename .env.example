# =============================================================================
# Import Software — Environment Variables (TEMPLATE)
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_NAME="Import Software"
APP_ENV=development                 # development | staging | production
APP_URL=http://localhost:8000
APP_DEBUG=true

# --- HostGator deployment (mirror these in GitHub repo Secrets) --------------
# Used by the GitHub Actions FTP deploy workflow. Do NOT put real values here;
# set them under Settings > Secrets and variables > Actions on GitHub.
FTP_SERVER=ftp.yourdomain.com       # HostGator FTP host
FTP_USERNAME=your-ftp-user
FTP_PASSWORD=your-ftp-password
FTP_SERVER_DIR=/public_html/        # target dir on HostGator

# --- Database (fill when the app needs one) ----------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_NAME=import_software
DB_USER=
DB_PASSWORD=

# --- Third-party / API keys (add as needed) ----------------------------------
# API_KEY=
