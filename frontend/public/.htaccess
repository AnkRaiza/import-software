# app.nisaro.tech — Import Cost Management tool (Apache / HostGator).

# --- Access control (HTTP Basic Auth) — DISABLED until .htpasswd exists ------
# To turn on password protection:
#   1) On the server (cPanel Terminal / SSH):  htpasswd -c ~/.htpasswd <username>
#   2) Uncomment the four lines below (and confirm the home path is correct).
# The password file lives OUTSIDE this deployed folder so FTP deploys never
# overwrite or delete it.
# AuthType Basic
# AuthName "Nisaro Tools"
# AuthUserFile /home3/clownart/.htpasswd
# Require valid-user

# --- SPA routing ------------------------------------------------------------
# Any request that is not a real file/directory -> index.html so React Router
# can handle client-side routes on refresh / deep links.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  RewriteRule ^ index.html [L]
</IfModule>

# --- Caching for hashed static assets ---------------------------------------
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>
