  "modules": {
    "products": {
      "title": "Product Catalog",
      "subtitle": "Reusable catalog of importable products (SKU, dimensions, FOB price)",
      "features": [
        "Add/edit products: SKU, name, category, thickness, finish (1/2-side UV)",
        "Dimensions with auto-calculated area (m²), weight, unit FOB price",
        "Link products to suppliers",
        "Unlimited products with search and filtering"
      ]
    },
    "purchaseOrder": {
      "title": "Purchase Order",
      "subtitle": "Build an order from catalog products — FOB is always calculated",
      "features": [
        "Select supplier and products, enter quantities",
        "Auto-retrieve unit price, area, and weight from the catalog",
        "Auto-calculate line totals, total quantity/weight/area, and FOB total",
        "FOB is never entered manually (PRD rule)"
      ]
    },
    "logistics": {
      "title": "Logistics",
      "subtitle": "International, destination, and customs-broker costs",
      "features": [
        "International: ocean freight, insurance, BL service, other",
        "Destination: deconsolidation, warehouse, handling, customs release, monitoring, port charges",
        "Customs broker: brokerage, processing, local delivery, misc",
        "Auto-calculated subtotals and total logistics cost"
      ]
    },
    "customs": {
      "title": "Customs (SUNAT)",
      "subtitle": "Peruvian customs duties and taxes",
      "features": [
        "Inputs: exchange rate, Ad Valorem %, IGV %, IPM %, Perception %",
        "Auto-calculated CIF and tax base",
        "Ad Valorem, IGV, IPM, and Perception amounts",
        "Total SUNAT taxes"
      ]
    },
    "allocation": {
      "title": "Cost Allocation",
      "subtitle": "Distribute logistics and taxes across products",
      "features": [
        "Allocation methods: by quantity, weight, area (m²), or FOB value",
        "Proportional logistics and tax allocation per product",
        "Final table: FOB, logistics, tax, landed cost, cost/unit, cost/m²",
        "Recomputed instantly by the shared calc engine"
      ]
    },
    "pricing": {
      "title": "Pricing",
      "subtitle": "Selling prices and margins from landed cost",
      "features": [
        "Margin tiers: 20%, 25%, 30%, 35%, 40%, 50%",
        "Selling price, gross profit, and margin per tier",
        "Custom target margin",
        "Driven by the landed cost from allocation"
      ]
    },
    "history": {
      "title": "Import History",
      "subtitle": "Every saved import, with comparison",
      "features": [
        "Record per import: date, supplier, FOB, logistics, taxes, total cost",
        "Compare imports side by side",
        "Cost evolution over time",
        "Excel/JSON export and import (secure library TBD)"
      ]
    },
    "simulator": {
      "title": "Scenario Simulator",
      "subtitle": "Change inputs and see landed cost recalculate instantly",
      "features": [
        "Adjust exchange rate, freight, insurance, tax rates, quantities",
        "Everything recalculates instantly (client-side engine)",
        "Compare against the base scenario",
        "No round-trips — pure in-browser math"
      ]
    }
  }
